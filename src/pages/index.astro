---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
  <main class="flex-1 flex flex-col">
    <!-- Hero Section -->
    <section class="bg-brutal-pink border-b-4 border-brutal-border p-8 md:p-20 text-center flex flex-col items-center justify-center flex-1 relative overflow-hidden min-h-[70vh]">
      <!-- Background Decorative Elements -->
      <div class="absolute top-10 left-10 w-24 h-24 bg-brutal-yellow border-4 border-brutal-border rounded-full animate-bounce mix-blend-multiply opacity-80 hidden md:block"></div>
      <div class="absolute bottom-10 right-10 w-32 h-32 bg-brutal-blue border-4 border-brutal-border transform rotate-12 hover:rotate-45 transition-transform duration-500 hidden md:block"></div>
      <div class="absolute top-1/4 right-20 w-16 h-16 bg-white border-4 border-brutal-border transform rotate-45 hidden lg:block"></div>
      
      <div class="max-w-4xl mx-auto relative z-10">
        <h1 class="text-7xl md:text-9xl font-black uppercase tracking-tighter mb-8 bg-white border-8 border-brutal-border inline-block px-8 py-4 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-2 hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] transition-all transform -rotate-1">
          agengit
        </h1>
        
        <p class="text-2xl md:text-4xl font-bold mb-12 max-w-3xl mx-auto leading-tight bg-brutal-yellow border-4 border-brutal-border p-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transform rotate-1">
          The CLI that records AI-agent coding activity so you can inspect what happened between commits.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-6 justify-center mt-8">
          <a href="/docs/getting-started" class="text-2xl md:text-3xl font-black uppercase bg-brutal-blue border-4 border-brutal-border px-10 py-5 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-2 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] active:translate-y-1 active:shadow-none transition-all">
            Get Started
          </a>
          <a href="https://github.com/matt-riley/agengit" target="_blank" class="text-2xl md:text-3xl font-black uppercase bg-white border-4 border-brutal-border px-10 py-5 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-2 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] active:translate-y-1 active:shadow-none transition-all">
            GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="p-8 md:p-24 bg-white">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-6xl md:text-7xl font-black uppercase mb-20 text-center">
          <span class="bg-brutal-text text-white px-6 py-3 transform -rotate-2 inline-block shadow-[8px_8px_0px_0px_var(--color-brutal-yellow)] border-4 border-brutal-text">Why agengit?</span>
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <div class="bg-brutal-yellow border-4 border-brutal-border p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-2 hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] transition-all">
            <div class="w-16 h-16 bg-white border-4 border-brutal-border rounded-full flex items-center justify-center text-3xl font-black mb-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">1</div>
            <h3 class="text-4xl font-black uppercase mb-4">Visibility</h3>
            <p class="text-xl font-medium leading-relaxed">Git tracks commit history. <span class="font-bold bg-white px-2 border-2 border-brutal-border">agengit</span> tracks agent execution history. See exactly what happened inside the black box.</p>
          </div>
          
          <div class="bg-brutal-blue border-4 border-brutal-border p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-2 hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] transition-all md:transform md:translate-y-8">
            <div class="w-16 h-16 bg-white border-4 border-brutal-border rounded-full flex items-center justify-center text-3xl font-black mb-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">2</div>
            <h3 class="text-4xl font-black uppercase mb-4">Investigate</h3>
            <p class="text-xl font-medium leading-relaxed">Use tools like <code class="bg-white border-2 border-brutal-border px-2 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">agit diff</code> and <code class="bg-white border-2 border-brutal-border px-2 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">agit timeline</code> to instantly verify AI changes and prompts.</p>
          </div>
          
          <div class="bg-brutal-pink border-4 border-brutal-border p-8 shadow-[12px_12px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-2 hover:shadow-[16px_16px_0px_0px_rgba(0,0,0,1)] transition-all">
            <div class="w-16 h-16 bg-white border-4 border-brutal-border rounded-full flex items-center justify-center text-3xl font-black mb-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">3</div>
            <h3 class="text-4xl font-black uppercase mb-4">Integrated</h3>
            <p class="text-xl font-medium leading-relaxed">Supports Claude Code, Copilot CLI, Gemini, and more. Install them all at once with <code class="bg-white border-2 border-brutal-border px-2 py-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">agit init</code>.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
