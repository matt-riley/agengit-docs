---
import '../styles/global.css';
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <Seo title={`${title} | agengit`} description={description || "The CLI that records AI-agent coding activity so you can inspect what happened between commits."} />
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts for Brutalist Vibe -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen border-8 border-brutal-border flex flex-col">
    <nav class="border-b-4 border-brutal-border bg-brutal-yellow p-4 flex justify-between items-center sticky top-0 z-50">
      <a href="/" class="text-3xl font-black uppercase tracking-tight hover:scale-105 transition-transform bg-white border-4 border-brutal-border px-3 py-1 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">agengit</a>
      <div class="space-x-4 font-bold flex items-center">
        <a href="/docs/getting-started" class="hover:bg-brutal-pink hover:text-black px-4 py-2 border-4 border-brutal-border bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] transition-all">DOCS</a>
        <a href="https://github.com/matt-riley/agengit" target="_blank" class="hover:bg-brutal-blue hover:text-black px-4 py-2 border-4 border-brutal-border bg-white shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:-translate-y-1 hover:shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] transition-all hidden sm:block">GITHUB</a>
      </div>
    </nav>
    <div class="flex-1 flex flex-col">
      <slot />
    </div>
  </body>
</html>
